# ── SQL Server ────────────────────────────────────────────────────────────────
# Format: HOSTNAME\INSTANCE  or  HOSTNAME,PORT
DB_SERVER=YOUR_PC\MSSQLSERVER2019
DB_DATABASE=AdventureWorksDW2019
DB_DRIVER=ODBC Driver 17 for SQL Server

# Windows Authentication (recommended) — leave both blank
DB_USER=
DB_PASSWORD=

# SQL Server Authentication — fill both if not using Windows auth
# DB_USER=sa
# DB_PASSWORD=YourPassword123

# Optional: comma-separated table whitelist (empty = auto-discover all tables)
# Example: DB_TABLE_FILTER=FactInternetSales,DimDate,DimProduct,DimCustomer
DB_TABLE_FILTER=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# ── SSAS (optional) ───────────────────────────────────────────────────────────
SSAS_CONNECTION_STRING=
