# ⬢ ARASAKA // GAWAIN ENGINE — Docker .env example
# Copy to .env and edit — this version is Docker-aware
# cp .env.example .env  or cp .env.docker.example .env

# ── SQL Server ───────────────────────────────────────────────
# For Docker → Host SQL Server (your Windows SSMS instance):
# Use host.docker.internal to reach host from container
# Example: host.docker.internal\SQLEXPRESS,1433  or  host.docker.internal,1433
DB_SERVER=host.docker.internal\SQLEXPRESS
DB_DATABASE=AdventureWorksDW2019
DB_DRIVER=ODBC Driver 17 for SQL Server

# Windows Auth won't work inside Linux container — use SQL Auth:
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd123

# If you uncomment mssql service in docker-compose.yml, use:
# DB_SERVER=mssql
# DB_DATABASE=AdventureWorksDW2019

# Optional table filter
DB_TABLE_FILTER=

# ── Ollama ───────────────────────────────────────────────────
# Inside docker-compose, app reaches ollama via service name
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:latest

# ── App ──────────────────────────────────────────────────────
# No need to change
    